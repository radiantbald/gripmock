POSTGRES_DB=gripmock
POSTGRES_USER=gripmock
POSTGRES_PASSWORD=change_me
LOG_LEVEL=info

# Direct GripMock host ports (used by `make up`).
GRIPMOCK_GRPC_PORT=4770
GRIPMOCK_HTTP_PORT=4771

# Traefik host ports (used by `make up-proxy`).
# Keep different from GripMock direct ports to avoid conflicts.
TRAEFIK_GRPC_PORT=5770
TRAEFIK_HTTP_PORT=5771

# Host path to stubs directory.
GRIPMOCK_STUBS_DIR=./examples/projects/greeter/stubs

# Host path to proto directory and proto file name.
GRIPMOCK_PROTO_DIR=./examples/projects/greeter
GRIPMOCK_PROTO_FILE=service.proto
